# ===================================================================
# Engineering Manager Platform v2.0 — Environment Configuration
# ===================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# --- Security [REQUIRED] ---
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-64-characters-recommended-change-this
DB_ENCRYPTION_KEY=           # Fernet key. If empty, one will be auto-generated on first run.

# --- LLM Providers [at least one REQUIRED] ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LLM Settings ---
DEFAULT_MODEL=gpt-4o
DEFAULT_TEMPERATURE=0.0
MAX_ITERATIONS=10

# --- Database ---
# Leave empty for SQLite (dev). Set to PostgreSQL URL for production.
# Example: postgresql+asyncpg://user:password@localhost:5432/daily_agents
DATABASE_URL=

# --- JWT ---
JWT_EXPIRE_MINUTES=43200     # 30 days

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Microsoft Teams Bot ---
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_BOT_USER_ID=

# --- Azure Speech (Transcription) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Email (SMTP) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=

# --- Application ---
BASE_URL=http://localhost:8000

# --- LangSmith Tracing (Optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=daily-agents
